import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { LayoutState } from "../../states/layout-state.slint";
import { ObjectsState } from "../../states/objects-state.slint";
import { PluginState } from "../../states/plugin-state.slint";
import { ObjectList } from "../panels/object-list.slint";
import { SelectionList } from "../panels/selection-list.slint";
import { ActionPill } from "../panels/action-pill.slint";
import { PluginPanelView } from "../panels/plugin-panel-view.slint";

// Right dock — hosts Objects + Selections panels with action pill overlay.
export component RightDock inherits Rectangle {
    clip: true;
    background: Theme.bg-raised;

    property <bool> builtins-visible:
        !LayoutState.empty-mode && (LayoutState.objects-visible || LayoutState.selections-visible);

    VerticalLayout {
        if root.builtins-visible: Rectangle {
            clip: true;
            height: PluginState.right-visible ? 50% : 100%;

            VerticalLayout {
                // Objects
                if LayoutState.objects-visible: Rectangle {
                    clip: true;
                    height: LayoutState.selections-visible ? 50% : 100%;
                    ObjectList {
                        width: 100%;
                        height: 100%;
                    }
                }

                // Separator (only when both are visible)
                if LayoutState.objects-visible && LayoutState.selections-visible: Rectangle {
                    height: Tokens.hairline;
                    background: Theme.line;
                }

                // Selections
                if LayoutState.selections-visible: Rectangle {
                    clip: true;
                    height: LayoutState.objects-visible ? 50% : 100%;
                    SelectionList {
                        width: 100%;
                        height: 100%;
                    }
                }
            }
        }

        if root.builtins-visible && PluginState.right-visible: Rectangle {
            height: Tokens.hairline;
            background: Theme.line;
        }

        if PluginState.right-visible: Rectangle {
            clip: true;
            height: root.builtins-visible ? 50% : 100%;

            VerticalLayout {
                if PluginState.right-tabs.length > 1: HorizontalLayout {
                    height: Tokens.tab-bar-h;
                    padding-left: Tokens.space-md;
                    spacing: Tokens.space-md;

                    for tab in PluginState.right-tabs: Rectangle {
                        width: tab-label.preferred-width;
                        height: parent.height;

                        tab-label := Text {
                            text: tab.title;
                            color: tab.active ? Theme.cyan : Theme.text-muted;
                            font-size: Tokens.font-md;
                            font-weight: 500;
                            letter-spacing: 1.1px;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => { PluginState.activate-panel(tab.id); }
                        }

                        Rectangle {
                            y: parent.height - 2px;
                            height: 2px;
                            width: 100%;
                            background: Theme.cyan;
                            opacity: tab.active ? 1.0 : 0.0;
                        }
                    }
                }

                PluginPanelView {
                    vertical-stretch: 1;
                    panel-id: PluginState.active-right-panel-id;
                    controls: PluginState.active-right-controls;
                }
            }
        }
    }

    // Action pill overlay — docked at the bottom, centered horizontally.
    if ObjectsState.selected-count > 0: ActionPill {
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - Tokens.action-pill-bottom-gap;
    }
}
