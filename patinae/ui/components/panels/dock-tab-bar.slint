import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { LayoutState } from "../../states/layout-state.slint";
import { PluginState } from "../../states/plugin-state.slint";

// Tab switcher for the bottom dock (Sequence | Movie).
// Tabs appear only when their panel is toggled on via sidebar.
export component DockTabBar inherits Rectangle {
    height: Tokens.tab-bar-h;
    background: transparent;

    HorizontalLayout {
        padding-left: Tokens.space-md;
        alignment: start;
        spacing: Tokens.space-md;

        // ── Sequence tab ──────────────────────────────────────────
        if LayoutState.sequence-visible: Rectangle {
            height: parent.height;
            width: seq-text.preferred-width;

            seq-text := Text {
                text: "SEQUENCE";
                color: LayoutState.bottom-active-tab == 0
                    ? Theme.cyan : Theme.text-muted;
                font-size: Tokens.font-md;
                font-weight: 500;
                letter-spacing: 1.1px;
                vertical-alignment: center;

                animate color { duration: Tokens.motion-micro; }
            }

            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    PluginState.deactivate-placement("bottom");
                    LayoutState.bottom-active-tab = 0;
                }
            }

            // Underline
            Rectangle {
                y: parent.height - 2px;
                height: 2px;
                width: 100%;
                background: Theme.cyan;
                opacity: LayoutState.bottom-active-tab == 0 ? 1.0 : 0.0;

                animate opacity { duration: Tokens.motion-micro; }
            }
        }

        // ── Movie tab ─────────────────────────────────────────────
        if LayoutState.movie-visible: Rectangle {
            height: parent.height;
            width: mov-text.preferred-width;

            mov-text := Text {
                text: "MOVIE";
                color: LayoutState.bottom-active-tab == 1
                    ? Theme.cyan : Theme.text-muted;
                font-size: Tokens.font-md;
                font-weight: 500;
                letter-spacing: 1.1px;
                vertical-alignment: center;

                animate color { duration: Tokens.motion-micro; }
            }

            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    PluginState.deactivate-placement("bottom");
                    LayoutState.bottom-active-tab = 1;
                }
            }

            // Underline
            Rectangle {
                y: parent.height - 2px;
                height: 2px;
                width: 100%;
                background: Theme.cyan;
                opacity: LayoutState.bottom-active-tab == 1 ? 1.0 : 0.0;

                animate opacity { duration: Tokens.motion-micro; }
            }
        }

        for tab in PluginState.bottom-tabs: Rectangle {
            height: parent.height;
            width: plug-text.preferred-width;

            plug-text := Text {
                text: tab.title;
                color: tab.active ? Theme.cyan : Theme.text-muted;
                font-size: Tokens.font-md;
                font-weight: 500;
                letter-spacing: 1.1px;
                vertical-alignment: center;
            }

            TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    LayoutState.bottom-active-tab = -1;
                    PluginState.activate-panel(tab.id);
                }
            }

            Rectangle {
                y: parent.height - 2px;
                height: 2px;
                width: 100%;
                background: Theme.cyan;
                opacity: tab.active ? 1.0 : 0.0;
            }
        }
    }

    // ── Bottom hairline ───────────────────────────────────────────
    Rectangle {
        y: parent.height - 0.5px;
        height: 0.5px;
        width: 100%;
        background: Theme.line;
    }
}
