import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { ObjectsState } from "../../states/objects-state.slint";

// ── Menu row (handles both separators and actions via is-separator) ──

component MenuRow inherits Rectangle {
    in property <string> action;
    in property <string> label;
    in property <bool> disabled;
    in property <bool> is-separator;

    width: 100%;
    height: root.is-separator ? 9px : 28px;

    // Separator line
    sep := Rectangle {
        visible: root.is-separator;
        width: 100%;
        height: 9px;
        background: transparent;

        Rectangle {
            x: Tokens.space-sm;
            y: 4px;
            width: parent.width - 2 * Tokens.space-sm;
            height: Tokens.hairline;
            background: Theme.line;
        }
    }

    // Clickable action
    action-rect := Rectangle {
        visible: !root.is-separator;
        width: 100%;
        height: 28px;
        border-radius: Tokens.radius-sm;
        background: root.disabled ? transparent
            : touch.has-hover ? Theme.bg-inset : transparent;
        opacity: root.disabled ? 0.4 : 1.0;

        Text {
            x: Tokens.space-sm;
            y: 0;
            width: parent.width - 2 * Tokens.space-sm;
            height: parent.height;
            text: root.label;
            color: root.disabled ? Theme.text-ghost
                : touch.has-hover ? Theme.text : Theme.text-dim;
            font-size: Tokens.font-md;
            font-weight: 500;
            vertical-alignment: center;
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                if !root.disabled {
                    ObjectsState.overflow-action(root.action);
                }
            }
        }
    }
}

// ── Overflow menu popover ────────────────────────────────────────────

export component OverflowMenu inherits Rectangle {
    width: 184px;
    height: inner.preferred-height;
    border-radius: Tokens.radius-md;
    background: Theme.bg-card;
    border-width: Tokens.hairline;
    border-color: Theme.line;

    TouchArea {}

    inner := VerticalLayout {
        padding: Tokens.space-xs;
        spacing: 0px;

        for item in ObjectsState.overflow-menu-items: MenuRow {
            action: item.action;
            label: item.label;
            disabled: item.disabled;
            is-separator: item.action == "separator";
        }
    }
}
