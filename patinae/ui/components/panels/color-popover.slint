import { Theme, NamedColor } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { ObjectsState } from "../../states/objects-state.slint";

// ── Section label ──────────────────────────────────────────────────

component SectionLabel inherits Text {
    color: Theme.text-ghost;
    font-size: Tokens.font-xs;
    font-weight: 500;
    letter-spacing: 1.1px;
    vertical-alignment: center;
    height: 14px;
}

// ── Scheme card ────────────────────────────────────────────────────

component SchemeCard inherits Rectangle {
    in property <string> scheme-id;
    in property <string> label;
    in property <string> cmd-text;
    in property <bool> disabled: false;
    in property <color> ic1: transparent;
    in property <color> ic2: transparent;
    in property <color> ic3: transparent;
    in property <color> ic4: transparent;
    in property <bool> has-ic4: false;
    in property <bool> dots: false;       // circles instead of squares
    in property <bool> has-custom-icon: false;

    height: 42px;
    preferred-width: 0px;
    min-width: 0px;
    border-radius: Tokens.radius-sm;
    border-width: Tokens.hairline;
    border-color: root.disabled ? Theme.line
        : card-touch.has-hover ? Theme.line-strong : Theme.line;
    background: root.disabled ? transparent
        : card-touch.has-hover ? Theme.bg-inset : Theme.bg-raised;
    opacity: root.disabled ? 0.4 : 1.0;

    // Default icons — hidden when custom icon is used
    property <length> icon-count-width: root.has-ic4 ? 38px : 28px;
    Rectangle {
        visible: !root.has-custom-icon;
        x: (parent.width - root.icon-count-width) / 2;
        y: 8px;
        width: root.icon-count-width;
        height: 8px;

        Rectangle { x: 0px;  width: 8px; height: 8px; border-radius: root.dots ? 4px : 2px; background: root.ic1; }
        Rectangle { x: 10px; width: 8px; height: 8px; border-radius: root.dots ? 4px : 2px; background: root.ic2; }
        Rectangle { x: 20px; width: 8px; height: 8px; border-radius: root.dots ? 4px : 2px; background: root.ic3; }
        Rectangle { x: 30px; width: 8px; height: 8px; border-radius: root.dots ? 4px : 2px; background: root.ic4;
                    visible: root.has-ic4; }
    }

    // Custom icon area
    Rectangle {
        y: 4px;
        width: 100%;
        height: 14px;
        @children
    }

    Text {
        y: 20px;
        width: 100%;
        height: 18px;
        text: root.label;
        color: root.disabled ? Theme.text-ghost
            : card-touch.has-hover ? Theme.text : Theme.text-dim;
        font-size: Tokens.font-sm;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    card-touch := TouchArea {
        enabled: !root.disabled;
        changed has-hover => {
            if self.has-hover {
                ObjectsState.popover-cmd-preview = root.cmd-text;
            }
        }
        clicked => {
            ObjectsState.popover-execute();
        }
    }
}

// ── Color swatch ───────────────────────────────────────────────────

component ColorSwatch inherits Rectangle {
    in property <string> color-name;
    in property <color> swatch-color;
    in property <string> cmd-text;

    horizontal-stretch: 1;
    height: self.width;
    border-radius: 4px;
    background: root.swatch-color;
    border-width: swatch-touch.has-hover ? 1.5px : 0px;
    border-color: Theme.text;

    swatch-touch := TouchArea {
        changed has-hover => {
            if self.has-hover {
                ObjectsState.popover-cmd-preview = root.cmd-text;
            }
        }
        clicked => {
            ObjectsState.popover-execute();
        }
    }
}

// ── Scope button ───────────────────────────────────────────────────

component ScopeButton inherits Rectangle {
    in property <string> scope-id;
    in property <string> label;
    in property <bool> disabled: false;

    property <bool> active: !root.disabled && ObjectsState.popover-scope == root.scope-id;

    horizontal-stretch: 1;
    preferred-width: 0px;
    min-width: 0px;
    height: 22px;
    border-radius: Tokens.radius-sm;
    border-width: root.active ? 1px : Tokens.hairline;
    border-color: root.disabled ? Theme.line
        : root.active ? Theme.cyan
        : scope-touch.has-hover ? Theme.line-strong : Theme.line;
    background: root.disabled ? transparent
        : root.active ? Theme.cyan.with-alpha(0.12)
        : scope-touch.has-hover ? Theme.bg-inset : Theme.bg-raised;
    opacity: root.disabled ? 0.4 : 1.0;

    Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: root.disabled ? Theme.text-ghost
            : root.active ? Theme.cyan
            : scope-touch.has-hover ? Theme.text : Theme.text-dim;
        font-size: Tokens.font-sm;
        font-weight: root.active ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    scope-touch := TouchArea {
        enabled: !root.disabled;
        clicked => {
            ObjectsState.popover-scope = root.scope-id;
        }
    }
}

// ── Scope icon button (rep-toggle style + scope behavior) ─────────

component ScopeIconButton inherits Rectangle {
    in property <string> scope-id;
    in property <string> label;
    in property <bool> disabled: false;

    property <bool> active: !root.disabled && ObjectsState.popover-scope == root.scope-id;
    out property <color> tint: root.disabled ? Theme.text-ghost
        : root.active ? Theme.cyan
        : scope-touch.has-hover ? Theme.text : Theme.text-dim;

    horizontal-stretch: 1;
    preferred-width: 0px;
    min-width: 0px;
    height: 36px;
    border-radius: Tokens.radius-sm;
    border-width: root.active ? 1px : Tokens.hairline;
    border-color: root.disabled ? Theme.line
        : root.active ? Theme.cyan
        : scope-touch.has-hover ? Theme.line-strong : Theme.line;
    background: root.disabled ? transparent
        : root.active ? Theme.cyan.with-alpha(0.12)
        : scope-touch.has-hover ? Theme.bg-inset : Theme.bg-raised;
    opacity: root.disabled ? 0.4 : 1.0;

    // Icon area (10×10, centered horizontally, top-aligned)
    Rectangle {
        x: (parent.width - 10px) / 2;
        y: 5px;
        width: 10px;
        height: 10px;
        @children
    }

    Text {
        y: 18px;
        width: 100%;
        height: 16px;
        text: root.label;
        color: root.tint;
        font-size: Tokens.font-sm;
        font-weight: root.active ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    scope-touch := TouchArea {
        enabled: !root.disabled;
        clicked => {
            ObjectsState.popover-scope = root.scope-id;
        }
    }
}

// ── Color popover ──────────────────────────────────────────────────

export component ColorPopover inherits Rectangle {
    height: inner.preferred-height;
    border-radius: Tokens.radius-md;
    background: Theme.bg-card;
    border-width: Tokens.hairline;
    border-color: Theme.line;

    // Block empty-surface clicks from falling through to the dismiss backdrop.
    TouchArea {}

    property <string> target: ObjectsState.popover-scope == "all-c"
        ? ObjectsState.popover-target + " and elem C"
        : ObjectsState.popover-target;
    property <string> scope: ObjectsState.popover-scope;
    // True when the popover targets a biopolymer or organic subchain (or object-level).
    property <bool> is-bio-or-organic: ObjectsState.popover-subchain-kind == ""
        || ObjectsState.popover-subchain-kind == "biopolymer"
        || ObjectsState.popover-subchain-kind == "organic";
    // True only for biopolymer subchains (or object-level).
    property <bool> is-bio: ObjectsState.popover-subchain-kind == ""
        || ObjectsState.popover-subchain-kind == "biopolymer";
    // Command prefix based on scope
    property <string> scope-prefix: root.scope == "all" || root.scope == "all-c" ? "color "
        : root.scope == "cartoon" ? "set cartoon_color, "
        : root.scope == "sticks" ? "set stick_color, "
        : root.scope == "lines" ? "set line_color, "
        : root.scope == "spheres" ? "set sphere_color, "
        : root.scope == "surface" ? "set surface_color, "
        : root.scope == "mesh" ? "set mesh_color, "
        : root.scope == "dots" ? "set dot_color, "
        : root.scope == "ribbon" ? "set ribbon_color, "
        : "color ";

    inner := VerticalLayout {
        padding: Tokens.space-sm;
        spacing: Tokens.space-sm;

        // Header
        HorizontalLayout {
            alignment: space-between;
            height: 18px;
            padding-left: Tokens.space-xs;
            padding-right: Tokens.space-xs;

            Text {
                text: "COLOR";
                color: Theme.text-muted;
                font-size: Tokens.font-xs;
                font-weight: 500;
                letter-spacing: 1.1px;
                vertical-alignment: center;
            }

            Text {
                text: ObjectsState.popover-display-label;
                color: Theme.text-ghost;
                font-size: Tokens.font-xs;
                vertical-alignment: center;
            }
        }

        // ── SCOPE ──
        SectionLabel { text: "SCOPE"; }

        VerticalLayout {
            spacing: 2px;

            HorizontalLayout {
                spacing: 1px;
                ScopeButton { scope-id: "all"; label: "all"; }
                ScopeButton { scope-id: "all-c"; label: "all C"; disabled: !root.is-bio-or-organic; }
            }

            HorizontalLayout {
                spacing: 2px;

                // Lines — zigzag wireframe
                ScopeIconButton {
                    scope-id: "lines"; label: "lines";
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 1 8 L 5 2 L 9 8";
                        stroke: parent.tint; stroke-width: 1px;
                    }
                }

                // Sticks — thick zigzag
                ScopeIconButton {
                    scope-id: "sticks"; label: "sticks";
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 1 8 L 5 2 L 9 8";
                        stroke: parent.tint; stroke-width: 2.5px;
                    }
                }

                // Spheres — filled circle
                ScopeIconButton {
                    scope-id: "spheres"; label: "spheres";
                    Rectangle { x: 1px; y: 1px; width: 8px; height: 8px; border-radius: 4px; background: parent.tint; }
                }

                // Cartoon — thick S-curve (helix ribbon)
                ScopeIconButton {
                    scope-id: "cartoon"; label: "cartoon"; disabled: !root.is-bio;
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 0 7 Q 2.5 0, 5 5 Q 7.5 10, 10 3";
                        stroke: parent.tint; stroke-width: 2px;
                    }
                }
            }

            HorizontalLayout {
                spacing: 2px;

                // Ribbon — thin S-curve trace
                ScopeIconButton {
                    scope-id: "ribbon"; label: "ribbon"; disabled: !root.is-bio;
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 0 7 Q 2.5 1, 5 5 Q 7.5 9, 10 3";
                        stroke: parent.tint; stroke-width: 1px;
                    }
                }

                // Surface — filled pentagon
                ScopeIconButton {
                    scope-id: "surface"; label: "surface";
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 5 0.5 L 9.3 3.6 L 7.6 8.6 L 2.4 8.6 L 0.7 3.6 Z";
                        fill: parent.tint;
                    }
                }

                // Mesh — pentagon with diagonals
                ScopeIconButton {
                    scope-id: "mesh"; label: "mesh";
                    Path {
                        width: 10px; height: 10px;
                        commands: "M 5 0.5 L 9.3 3.6 L 7.6 8.6 L 2.4 8.6 L 0.7 3.6 Z M 5 0.5 L 2.4 8.6 M 5 0.5 L 7.6 8.6";
                        stroke: parent.tint; stroke-width: 0.8px;
                    }
                }

                // Dots — pentagon vertices
                ScopeIconButton {
                    scope-id: "dots"; label: "dots";
                    Rectangle { x: 4px;   y: -0.5px; width: 2px; height: 2px; border-radius: 1px; background: parent.tint; }
                    Rectangle { x: 8.3px; y: 2.6px;  width: 2px; height: 2px; border-radius: 1px; background: parent.tint; }
                    Rectangle { x: 6.6px; y: 7.6px;  width: 2px; height: 2px; border-radius: 1px; background: parent.tint; }
                    Rectangle { x: 1.4px; y: 7.6px;  width: 2px; height: 2px; border-radius: 1px; background: parent.tint; }
                    Rectangle { x: -0.3px; y: 2.6px; width: 2px; height: 2px; border-radius: 1px; background: parent.tint; }
                }
            }
        }

        // Separator
        Rectangle {
            height: Tokens.hairline;
            background: Theme.line;
        }

        // ── SOLID ──
        SectionLabel { text: "SOLID"; }

        VerticalLayout {
            spacing: 4px;

            HorizontalLayout {
                spacing: 4px;
                for entry in Theme.solid-row1: ColorSwatch {
                    color-name: entry.name;
                    swatch-color: entry.swatch;
                    cmd-text: root.scope-prefix + entry.name + ", " + root.target;
                }
            }

            HorizontalLayout {
                spacing: 4px;
                for entry in Theme.solid-row2: ColorSwatch {
                    color-name: entry.name;
                    swatch-color: entry.swatch;
                    cmd-text: root.scope-prefix + entry.name + ", " + root.target;
                }
            }

            HorizontalLayout {
                spacing: 4px;
                for entry in Theme.solid-row3: ColorSwatch {
                    color-name: entry.name;
                    swatch-color: entry.swatch;
                    cmd-text: root.scope-prefix + entry.name + ", " + root.target;
                }
            }
        }

        // Separator
        Rectangle {
            height: Tokens.hairline;
            background: Theme.line;
        }

        // ── SCHEME ──
        SectionLabel { text: "SCHEME"; }

        VerticalLayout {
            spacing: 2px;

            HorizontalLayout {
                spacing: 2px;
                SchemeCard {
                    scheme-id: "chain";
                    label: "by chain";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "chain, " + root.target;
                    disabled: ObjectsState.popover-chain-id != "" || !root.is-bio;
                    ic1: Theme.chain-a; ic2: Theme.chain-b; ic3: Theme.chain-c;
                }

                SchemeCard {
                    scheme-id: "ss";
                    label: "by ss";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "ss, " + root.target;
                    disabled: !root.is-bio;
                    has-custom-icon: true;

                    // Helix – loop – strand arrow
                    Rectangle {
                        x: (parent.width - 38px) / 2;
                        width: 38px;
                        height: 8px;

                        // Helix wave (magenta) — smooth sine
                        Path {
                            x: 0px; y: 0px;
                            width: 12px; height: 8px;
                            commands: "M 0 5 Q 3 -1, 6 4 Q 9 9, 12 3";
                            stroke: Theme.ss-helix;
                            stroke-width: 1.5px;
                        }

                        // Loop dash (grey)
                        Rectangle {
                            x: 14px; y: 3px;
                            width: 10px; height: 1.5px;
                            background: Theme.ss-loop;
                            border-radius: 0.75px;
                        }

                        // Strand arrow body (amber)
                        Rectangle {
                            x: 26px; y: 2.5px;
                            width: 8px; height: 3px;
                            background: Theme.ss-sheet;
                            border-radius: 0.5px;
                        }

                        // Strand arrow head (amber)
                        Path {
                            x: 33px; y: 0px;
                            width: 5px; height: 8px;
                            commands: "M 0 0 L 5 4 L 0 8 Z";
                            fill: Theme.ss-sheet;
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 2px;
                SchemeCard {
                    scheme-id: "element";
                    label: "by element";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "atomic, " + root.target;
                    has-custom-icon: true;

                    // Alanine: N — Cα(—Cβ) — C'(=O)(—O)
                    // Bonds drawn first, atoms on top cover bond endpoints
                    Rectangle {
                        x: (parent.width - 28px) / 2;
                        width: 28px;
                        height: 14px;

                        // ── Bonds (1px) ──
                        Rectangle { x: 4px;  y: 7.5px; width: 4px; height: 1px; background: Theme.text-muted; }  // N—Cα
                        Rectangle { x: 12px; y: 7.5px; width: 4px; height: 1px; background: Theme.text-muted; }  // Cα—C'
                        Rectangle { x: 20px; y: 7.5px; width: 4px; height: 1px; background: Theme.text-muted; }  // C'—O right
                        Rectangle { x: 9.5px; y: 9px;  width: 1px; height: 2px; background: Theme.text-muted; }  // Cα—Cβ
                        Rectangle { x: 17px; y: 4px;   width: 1px; height: 2px; background: Theme.text-muted; }  // C'=O line 1
                        Rectangle { x: 18px; y: 4px;   width: 1px; height: 2px; background: Theme.text-muted; }  // C'=O line 2

                        // ── Atoms (all 4×4) ──
                        Rectangle { x: 0px;  y: 6px; width: 4px; height: 4px; border-radius: 2px; background: #617ED8; }  // N
                        Rectangle { x: 8px;  y: 6px; width: 4px; height: 4px; border-radius: 2px; background: #6F7A8A; }  // Cα
                        Rectangle { x: 16px; y: 6px; width: 4px; height: 4px; border-radius: 2px; background: #6F7A8A; }  // C'
                        Rectangle { x: 24px; y: 6px; width: 4px; height: 4px; border-radius: 2px; background: #E05C6C; }  // O right
                        Rectangle { x: 16px; y: 0px; width: 4px; height: 4px; border-radius: 2px; background: #E05C6C; }  // O top
                        Rectangle { x: 8px; y: 10px; width: 4px; height: 4px; border-radius: 2px; background: #6F7A8A; }  // Cβ
                    }
                }

                SchemeCard {
                    scheme-id: "bfactor";
                    label: "by b-factor";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "b, " + root.target;
                    ic1: #3B82F6; ic2: #A78BFA; ic3: #EF4444;
                }
            }

            HorizontalLayout {
                spacing: 2px;
                SchemeCard {
                    scheme-id: "residue";
                    label: "by residue";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "residue, " + root.target;
                    disabled: !root.is-bio;
                    has-custom-icon: true;

                    // 5 residue-type color dots
                    Rectangle {
                        x: (parent.width - 38px) / 2;
                        width: 38px;
                        height: 8px;

                        Rectangle { x: 0px;  y: 1px; width: 6px; height: 6px; border-radius: 3px; background: #BDB091; } // hydrophobic
                        Rectangle { x: 8px;  y: 1px; width: 6px; height: 6px; border-radius: 3px; background: #7091DF; } // positive
                        Rectangle { x: 16px; y: 1px; width: 6px; height: 6px; border-radius: 3px; background: #E77D89; } // negative
                        Rectangle { x: 24px; y: 1px; width: 6px; height: 6px; border-radius: 3px; background: #7FC4CF; } // polar
                        Rectangle { x: 32px; y: 1px; width: 6px; height: 6px; border-radius: 3px; background: #E6C640; } // cysteine
                    }
                }

                SchemeCard {
                    scheme-id: "index";
                    label: "by index";
                    horizontal-stretch: 1;
                    cmd-text: root.scope-prefix + "index, " + root.target;
                    disabled: !root.is-bio;
                    ic1: #3B82F6; ic2: #22C55E; ic3: #EAB308; ic4: #EF4444;
                    has-ic4: true;
                }
            }
        }

        // Command preview footer
        HorizontalLayout {
            height: 22px;
            spacing: 0px;

            // CMD badge
            Rectangle {
                width: cmd-label.preferred-width + 2 * Tokens.space-sm;
                height: parent.height;
                border-radius: Tokens.radius-sm;
                background: Theme.bg-raised;

                cmd-label := Text {
                    width: 100%;
                    height: 100%;
                    text: "CMD";
                    color: Theme.text-ghost;
                    font-size: Tokens.font-sm;
                    font-weight: 600;
                    letter-spacing: 0.8px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Command text
            Rectangle {
                horizontal-stretch: 1;
                height: parent.height;
                border-radius: Tokens.radius-sm;
                background: Theme.bg-inset;

                Text {
                    x: Tokens.space-sm;
                    width: parent.width - 2 * Tokens.space-sm;
                    height: 100%;
                    text: ObjectsState.popover-cmd-preview;
                    color: Theme.text-muted;
                    font-size: Tokens.font-sm;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}
