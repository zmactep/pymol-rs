component PluginNodeButtonRow inherits Rectangle {
    in property <PluginControlNode> control;
    in property <string> panel-id;

    height: 24px;

    HorizontalLayout {
        spacing: Tokens.space-xs;

        for button in root.control.buttons: PluginIconButton {
            button: button;
            panel-id: root.panel-id;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }
    }
}

component PluginControlNodeRow inherits Rectangle {
    in property <PluginControlNode> control;
    in property <string> panel-id;

    height: root.control.kind == "text" ? max(root.control.height * 1px, text-row.preferred-height)
        : max(4px, root.control.height * 1px);

    if control.kind == "heading": Text {
        text: root.control.text;
        color: Theme.text;
        font-size: Tokens.font-md;
        font-weight: 600;
        vertical-alignment: center;
    }

    text-row := Text {
        visible: root.control.kind == "text";
        text: root.control.text;
        color: Theme.text-muted;
        font-size: Tokens.font-sm;
        wrap: word-wrap;
    }

    if control.kind == "button": PluginNodeButton {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "button-row": PluginNodeButtonRow {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "text-area": PluginTextAreaNode {
        width: 100%;
        height: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "row": HorizontalLayout {
        spacing: root.control.gap * 1px;

        for node in root.control.leaf-children: PluginControlLeafRow {
            horizontal-stretch: node.grow;
            height: 100%;
            control: node;
            panel-id: root.panel-id;
        }
    }

    if control.kind == "column": VerticalLayout {
        spacing: root.control.gap * 1px;

        for node in root.control.leaf-children: PluginControlLeafRow {
            width: 100%;
            vertical-stretch: node.grow;
            control: node;
            panel-id: root.panel-id;
        }
    }

    if control.kind == "toggle": PluginNodeToggle {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "slider": PluginNodeSlider {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "number": PluginNodeTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "select": PluginNodeSelect {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "text-input": PluginNodeTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "image": Image {
        width: root.control.image-width * 1px;
        height: root.control.image-height * 1px;
        source: root.control.image-value;
        image-fit: contain;
    }
}

component PluginGroup inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: 100%;
    border-radius: Tokens.radius-md;
    background: Theme.bg-raised.with-alpha(0.50);
    border-width: Tokens.hairline;
    border-color: Theme.line.with-alpha(0.78);

    VerticalLayout {
        padding: 8px;
        spacing: root.control.gap * 1px;

        if root.control.label != "": Rectangle {
            height: 24px;

            Text {
                x: 2px;
                width: parent.width - 28px;
                height: 100%;
                text: root.control.label;
                color: Theme.text;
                font-size: Tokens.font-md;
                font-weight: 600;
                vertical-alignment: center;
            }

            if !root.control.open: Path {
                x: parent.width - 18px;
                y: 7px;
                width: 10px;
                height: 10px;
                viewbox-width: 10;
                viewbox-height: 10;
                commands: "M 3 2 L 7 5 L 3 8";
                stroke: Theme.cyan;
                stroke-width: 1.4px;
                fill: transparent;
            }

            if root.control.open: Path {
                x: parent.width - 18px;
                y: 7px;
                width: 10px;
                height: 10px;
                viewbox-width: 10;
                viewbox-height: 10;
                commands: "M 2 3 L 5 7 L 8 3";
                stroke: Theme.cyan;
                stroke-width: 1.4px;
                fill: transparent;
            }

            header-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    PluginState.control-event(root.panel-id, root.control.id, "toggle", "", 0, !root.control.open);
                }
            }
        }

        for node in root.control.children: PluginControlNodeRow {
            visible: root.control.open;
            width: 100%;
            vertical-stretch: node.grow;
            control: node;
            panel-id: root.panel-id;
        }
    }
}

component PluginControlRow inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: control.kind == "text" ? max(root.control.height * 1px, text-row.preferred-height)
        : max(4px, root.control.height * 1px);

    if control.kind == "heading": Text {
        width: 100%;
        text: root.control.text;
        color: Theme.text;
        font-size: Tokens.font-md;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    text-row := Text {
        visible: root.control.kind == "text";
        width: 100%;
        text: root.control.text;
        color: Theme.text-muted;
        font-size: Tokens.font-sm;
        wrap: word-wrap;
    }

    if control.kind == "section": Rectangle {
        height: 100%;
        border-radius: Tokens.radius-md;
        background: touch.has-hover ? Theme.bg-inset.with-alpha(0.72) : Theme.bg-raised.with-alpha(0.38);
        border-width: Tokens.hairline;
        border-color: touch.has-hover ? Theme.line-strong : Theme.line.with-alpha(0.70);

        Text {
            x: 10px;
            width: 12px;
            height: 100%;
            text: root.control.open ? "⌄" : "›";
            color: Theme.cyan;
            font-size: Tokens.font-md;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            x: 28px;
            width: parent.width - 38px;
            height: 100%;
            text: root.control.label;
            color: Theme.text;
            font-size: Tokens.font-md;
            font-weight: 600;
            vertical-alignment: center;
        }

        touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                PluginState.control-event(root.panel-id, root.control.id, "toggle", "", 0, !root.control.open);
            }
        }
    }

    if control.kind == "button": PluginButton {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "button-row": PluginButtonRow {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "row": HorizontalLayout {
        spacing: root.control.gap * 1px;

        for node in root.control.children: PluginControlNodeRow {
            horizontal-stretch: node.grow;
            height: 100%;
            control: node;
            panel-id: root.panel-id;
        }
    }

    if control.kind == "column": VerticalLayout {
        spacing: root.control.gap * 1px;

        for node in root.control.children: PluginControlNodeRow {
            width: 100%;
            vertical-stretch: node.grow;
            control: node;
            panel-id: root.panel-id;
        }
    }

    if control.kind == "group": PluginGroup {
        width: 100%;
        height: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "toggle": PluginToggle {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "slider": PluginSlider {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "number": PluginTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "select": PluginSelect {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "text-input": PluginTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "text-area": PluginTextArea {
        width: 100%;
        height: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "image": Image {
        width: root.control.image-width * 1px;
        height: root.control.image-height * 1px;
        source: root.control.image-value;
        image-fit: contain;
    }
}

export component PluginPanelView inherits Rectangle {
    in property <string> panel-id;
    in property <[PluginControl]> controls;

    background: Theme.bg-panel;
    clip: true;

    Flickable {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: 10px;
            spacing: 8px;

            for control in root.controls: PluginControlRow {
                width: 100%;
                control: control;
                panel-id: root.panel-id;
            }
        }
    }
}
