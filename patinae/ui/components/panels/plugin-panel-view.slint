component PluginControlLeafRow inherits Rectangle {
    in property <PluginControlLeaf> control;
    in property <string> panel-id;

    height: max(4px, root.control.height * 1px);

    if control.kind == "number": PluginLeafTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }

    if control.kind == "text-input": PluginLeafTextInput {
        width: 100%;
        control: root.control;
        panel-id: root.panel-id;
    }
}

component PluginTextAreaPane inherits Rectangle {
    in property <string> panel-id;
    in property <string> control-id;
    in property <string> label;
    in property <string> value-text;
    in property <string> placeholder;
    in property <bool> read-only;
    in property <[PluginHighlightLine]> highlight-lines;

    VerticalLayout {
        spacing: 4px;

        Text {
            visible: root.label != "";
            height: root.label == "" ? 0px : 14px;
            text: root.label;
            color: Theme.text-dim;
            font-size: Tokens.font-sm;
        }

        HighlightedTextArea {
            vertical-stretch: 1;
            min-height: 48px;
            identity: root.control-id;
            value-text: root.value-text;
            placeholder: root.placeholder;
            read-only: root.read-only;
            highlight-lines: root.highlight-lines;
            font-family: "JetBrains Mono";
            font-size: Tokens.font-md;

            edited(text) => {
                PluginState.control-event(root.panel-id, root.control-id, "text-area-edit", text, 0, false);
            }

            committed(text) => {
                PluginState.control-event(root.panel-id, root.control-id, "text-commit", text, 0, false);
            }
        }
    }
}

component PluginTextArea inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    PluginTextAreaPane {
        width: 100%;
        height: 100%;
        panel-id: root.panel-id;
        control-id: root.control.id;
        label: root.control.label;
        value-text: root.control.value-text;
        placeholder: root.control.text;
        read-only: root.control.read-only;
        highlight-lines: root.control.highlight-lines;
    }
}

component PluginTextAreaNode inherits Rectangle {
    in property <PluginControlNode> control;
    in property <string> panel-id;

    PluginTextAreaPane {
        width: 100%;
        height: 100%;
        panel-id: root.panel-id;
        control-id: root.control.id;
        label: root.control.label;
        value-text: root.control.value-text;
        placeholder: root.control.text;
        read-only: root.control.read-only;
        highlight-lines: root.control.highlight-lines;
    }
}

