import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { PluginState, PluginControl, PluginControlNode, PluginControlLeaf, PluginOption, PluginButtonItem, PluginHighlightLine } from "../../states/plugin-state.slint";
import { HighlightedTextArea } from "highlighted-text-area.slint";

component PluginButton inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: 32px;
    border-radius: Tokens.radius-sm;
    background: root.control.primary
        ? Theme.cyan.with-alpha(0.20)
        : touch.has-hover ? Theme.bg-inset : Theme.bg-raised.with-alpha(0.22);
    border-width: Tokens.hairline;
    border-color: root.control.primary
        ? Theme.cyan.with-alpha(0.68)
        : touch.has-hover ? Theme.line-strong : Theme.line.with-alpha(0.72);

    Text {
        text: root.control.label;
        color: root.control.primary ? Theme.cyan : Theme.text-dim;
        font-size: Tokens.font-md;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            PluginState.control-event(root.panel-id, root.control.id, "click", "", 0, false);
        }
    }
}

component PluginGlyph {
    in property <string> icon;
    in property <color> tint;

    width: 14px;
    height: 14px;

    if root.icon == "run": Path {
        width: 100%;
        height: 100%;
        viewbox-width: 16;
        viewbox-height: 16;
        commands: "M 5 3 L 12 8 L 5 13 Z";
        stroke: transparent;
        fill: root.tint;
    }

    if root.icon == "stop": Path {
        width: 100%;
        height: 100%;
        viewbox-width: 16;
        viewbox-height: 16;
        commands: "M 5 5 L 11 5 L 11 11 L 5 11 Z";
        stroke: transparent;
        fill: root.tint;
    }

    if root.icon == "clear": Path {
        width: 100%;
        height: 100%;
        viewbox-width: 16;
        viewbox-height: 16;
        commands: "M 5 6 L 11 6 M 6 6 L 6.5 13 L 9.5 13 L 10 6 M 7 4 L 9 4 M 4 5 L 12 5";
        stroke: root.tint;
        stroke-width: 1.3px;
        fill: transparent;
    }
}

component PluginIconButton inherits Rectangle {
    in property <PluginButtonItem> button;
    in property <string> panel-id;

    width: root.button.primary ? 32px : 28px;
    height: 24px;
    border-radius: Tokens.radius-sm;
    background: root.button.primary
        ? (root.button.enabled ? Theme.cyan.with-alpha(0.16) : transparent)
        : touch.has-hover && root.button.enabled ? Theme.bg-inset : transparent;
    border-width: Tokens.hairline;
    border-color: root.button.primary && root.button.enabled
        ? Theme.cyan.with-alpha(0.55)
        : touch.has-hover && root.button.enabled ? Theme.line-strong : Theme.line;
    opacity: root.button.enabled ? 1.0 : 0.35;

    PluginGlyph {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        icon: root.button.icon;
        tint: root.button.primary ? Theme.cyan : Theme.text-dim;
    }

    touch := TouchArea {
        enabled: root.button.enabled;
        mouse-cursor: pointer;
        clicked => {
            PluginState.control-event(root.panel-id, root.button.id, "click", "", 0, false);
        }
    }

    if touch.has-hover && root.button.enabled && root.button.label != "": Rectangle {
        y: parent.height + 4px;
        width: tooltip-text.preferred-width + 10px;
        height: 20px;
        border-radius: Tokens.radius-sm;
        background: Theme.bg-card;
        border-width: Tokens.hairline;
        border-color: Theme.line-strong;

        tooltip-text := Text {
            x: 5px;
            width: parent.width - 10px;
            height: 100%;
            text: root.button.label;
            color: Theme.text-dim;
            font-size: Tokens.font-sm;
            vertical-alignment: center;
        }
    }
}

component PluginButtonRow inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: 24px;

    HorizontalLayout {
        spacing: Tokens.space-xs;

        for button in root.control.buttons: PluginIconButton {
            button: button;
            panel-id: root.panel-id;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }
    }
}

component PluginToggle inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: 28px;

    HorizontalLayout {
        spacing: Tokens.space-sm;

        Rectangle {
            width: 24px;
            height: 100%;
            background: transparent;

            Rectangle {
                x: 0;
                y: (parent.height - self.height) / 2;
                width: 14px;
                height: 14px;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.control.bool-value ? Theme.cyan : Theme.text-ghost;
                background: root.control.bool-value ? Theme.cyan.with-alpha(0.20) : transparent;

                if root.control.bool-value: Path {
                    width: 10px;
                    height: 10px;
                    x: 2px;
                    y: 2px;
                    commands: "M 1 5 L 4 8 L 9 2";
                    stroke: Theme.cyan;
                    stroke-width: 1.5px;
                    fill: transparent;
                }
            }
        }

        Text {
            horizontal-stretch: 1;
            height: 100%;
            text: root.control.label;
            color: Theme.text-dim;
            font-size: Tokens.font-md;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            PluginState.control-event(
                root.panel-id,
                root.control.id,
                "toggle",
                "",
                0,
                !root.control.bool-value
            );
        }
    }
}

component PluginSlider inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;
    property <float> value: root.control.num-value;

    height: 38px;

    function snap-value(raw: float) -> float {
        return clamp(
            root.control.min + round((raw - root.control.min) / max(0.0001, root.control.step)) * max(0.0001, root.control.step),
            root.control.min,
            root.control.max
        );
    }

    function display-value() -> string {
        return root.control.step >= 1.0
            ? "" + round(root.value)
            : "" + (round(root.value * 100) / 100);
    }

    VerticalLayout {
        spacing: 3px;

        HorizontalLayout {
            Text {
                horizontal-stretch: 1;
                text: root.control.label;
                color: Theme.text-dim;
                font-size: Tokens.font-sm;
            }
            Text {
                width: 52px;
                text: root.display-value();
                color: Theme.cyan;
                font-family: "JetBrains Mono";
                font-size: Tokens.font-sm;
                horizontal-alignment: right;
            }
        }

        Rectangle {
            height: 12px;
            background: transparent;

            Rectangle {
                y: 2px;
                width: 100%;
                height: 8px;
                border-radius: 4px;
                background: Theme.bg-inset;
            }

            property <length> knob-size: 10px;

            property <float> denom: max(0.0001, root.control.max - root.control.min);
            property <float> pos: clamp((root.value - root.control.min) / self.denom, 0.0, 1.0);

            Rectangle {
                x: 0;
                y: 2px;
                width: parent.width * parent.pos;
                height: 8px;
                border-radius: 4px;
                background: Theme.cyan.with-alpha(0.45);
            }

            Rectangle {
                x: clamp(parent.width * parent.pos - parent.knob-size / 2, 0px, parent.width - parent.knob-size);
                y: 1px;
                width: parent.knob-size;
                height: parent.knob-size;
                border-radius: parent.knob-size / 2;
                background: touch.has-hover ? Theme.cyan : Theme.text-muted;
            }

            touch := TouchArea {
                mouse-cursor: pointer;
                pointer-event(event) => {
                    if event.kind == PointerEventKind.down || event.kind == PointerEventKind.up {
                        root.value = root.snap-value(root.control.min + parent.denom * clamp(self.mouse-x / parent.width, 0.0, 1.0));
                        PluginState.control-event(root.panel-id, root.control.id, "number", "", root.value, false);
                    }
                }
                moved => {
                    if self.pressed {
                        root.value = root.snap-value(root.control.min + parent.denom * clamp(self.mouse-x / parent.width, 0.0, 1.0));
                        PluginState.control-event(root.panel-id, root.control.id, "number", "", root.value, false);
                    }
                }
            }
        }
    }
}

component PluginOptionChip inherits Rectangle {
    in property <PluginOption> option;
    in property <PluginControl> control;
    in property <string> panel-id;
    property <bool> selected: root.option.value == root.control.value-text;

    width: max(42px, label.preferred-width + 16px);
    height: 24px;
    border-radius: Tokens.radius-sm;
    background: selected ? Theme.cyan.with-alpha(0.14) : touch.has-hover ? Theme.bg-inset : transparent;
    border-width: Tokens.hairline;
    border-color: selected ? Theme.cyan.with-alpha(0.55) : Theme.line;

    label := Text {
        text: root.option.label;
        color: root.selected ? Theme.cyan : Theme.text-muted;
        font-size: Tokens.font-sm;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            PluginState.control-event(root.panel-id, root.control.id, "select", root.option.value, 0, false);
        }
    }
}

component PluginSelect inherits VerticalLayout {
    in property <PluginControl> control;
    in property <string> panel-id;

    spacing: 4px;

    Text {
        text: root.control.label;
        color: Theme.text-dim;
        font-size: Tokens.font-sm;
    }

    HorizontalLayout {
        spacing: Tokens.space-xs;
        for option in root.control.options: PluginOptionChip {
            option: option;
            control: root.control;
            panel-id: root.panel-id;
        }
    }
}

component PluginTextInput inherits Rectangle {
    in property <PluginControl> control;
    in property <string> panel-id;

    height: 46px;

    VerticalLayout {
        spacing: 4px;

        Text {
            text: root.control.label;
            color: Theme.text-dim;
            font-size: Tokens.font-sm;
        }

        Rectangle {
            height: 28px;
            border-radius: Tokens.radius-sm;
            background: Theme.bg-inset.with-alpha(0.70);
            border-width: Tokens.hairline;
            border-color: input.has-focus ? Theme.cyan.with-alpha(0.65) : Theme.line;

            input := TextInput {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;
                text: root.control.value-text;
                single-line: true;
                color: Theme.text-dim;
                font-size: Tokens.font-md;
                vertical-alignment: center;
                selection-background-color: Theme.cyan.with-alpha(0.3);
                selection-foreground-color: Theme.text;

                edited => {
                    PluginState.control-event(root.panel-id, root.control.id, "text-edit", self.text, 0, false);
                }
                accepted => {
                    PluginState.control-event(root.panel-id, root.control.id, "text-commit", self.text, 0, false);
                }
            }
        }
    }
}

