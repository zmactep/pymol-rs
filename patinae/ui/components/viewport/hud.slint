import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { ViewportState } from "../../states/viewport-state.slint";

component PerfMemoryMetric inherits HorizontalLayout {
    in property <string> metric-label;
    in property <string> metric-value;

    spacing: 2px;
    alignment: center;

    Text {
        text: root.metric-label;
        color: Theme.text-faint;
        font-size: Tokens.font-xs;
    }
    Text {
        text: root.metric-value;
        color: Theme.text-muted;
        font-size: Tokens.font-xs;
    }
}

component PerfMemoryStrip inherits HorizontalLayout {
    in property <color> badge-color;

    height: 16px;
    spacing: 5px;
    alignment: end;

    Rectangle {
        width: badge-label.preferred-width + 2 * Tokens.space-xs;
        height: 16px;
        border-radius: Tokens.radius-sm;
        background: root.badge-color.with-alpha(0.16);
        border-width: Tokens.hairline;
        border-color: root.badge-color.with-alpha(0.42);

        badge-label := Text {
            width: 100%;
            height: 100%;
            text: ViewportState.perf-memory-profile-label;
            color: root.badge-color;
            font-size: Tokens.font-xs;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    PerfMemoryMetric {
        metric-label: "gpu";
        metric-value: ViewportState.perf-memory-total-text;
    }
    PerfMemoryMetric {
        metric-label: "live";
        metric-value: ViewportState.perf-memory-live-text;
    }
}

export component Hud inherits Rectangle {
    background: transparent;
    opacity: 0.55;
    width: layout.preferred-width;
    height: layout.preferred-height;

    property <color> indicator-color:
        ViewportState.fps-value >= 50 ? Theme.good
        : ViewportState.fps-value >= 25 ? Theme.warning
        : Theme.error;

    property <color> memory-profile-color:
        ViewportState.perf-memory-profile-label == "PERF" ? Theme.good
        : ViewportState.perf-memory-profile-label == "BAL" ? Theme.cyan
        : Theme.warning;

    layout := VerticalLayout {
        spacing: 2px;

        Text {
            text: ViewportState.device-name;
            color: Theme.text-muted;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        Text {
            text: ViewportState.engine-name;
            color: Theme.text-faint;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        HorizontalLayout {
            alignment: end;
            spacing: 4px;
            Rectangle {
                width: 4px;
                height: 4px;
                border-radius: 2px;
                background: root.indicator-color;
                y: (parent.height - self.height) / 2;
            }
            Text {
                text: ViewportState.fps-text;
                color: Theme.text-muted;
                font-size: Tokens.font-xs;
            }
        }
        // `PATINAE_PERF=1` → tail-latency rows + per-pass GPU times.
        if ViewportState.perf-visible: Text {
            text: ViewportState.perf-avg-text;
            color: Theme.text-muted;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        if ViewportState.perf-visible: Text {
            text: ViewportState.perf-low-1pct-text;
            color: Theme.text-muted;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        if ViewportState.perf-visible: Text {
            text: ViewportState.perf-low-0_1pct-text;
            color: Theme.text-muted;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        if ViewportState.perf-visible && ViewportState.perf-memory-profile-label != "": PerfMemoryStrip {
            badge-color: root.memory-profile-color;
        }
        if ViewportState.perf-visible && ViewportState.perf-gpu-text != "": Text {
            text: ViewportState.perf-gpu-text;
            color: Theme.text-faint;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
            wrap: word-wrap;
        }
    }
}
