import { Theme } from "../../theme.slint";
import { Tokens } from "../../tokens.slint";
import { ViewportState } from "../../states/viewport-state.slint";

// Thin separator between HUD sections; stretches to the card's content width.
component HudRule inherits Rectangle {
    height: Tokens.hairline;
    background: Theme.line;
}

// `label …………… value` row (label flush left, value flush right).
component StatRow inherits HorizontalLayout {
    in property <string> stat-label;
    in property <string> stat-value;

    alignment: space-between;
    spacing: Tokens.space-md;

    Text {
        text: root.stat-label;
        color: Theme.text-faint;
        font-size: Tokens.font-xs;
    }
    Text {
        text: root.stat-value;
        color: Theme.text-dim;
        font-size: Tokens.font-xs;
    }
}

// Memory section: profile badge + budget figure, a usage bar, and live bytes.
component MemoryPanel inherits VerticalLayout {
    in property <color> badge-color;
    spacing: 5px;

    // Bar fill warms up as the budget fills: green → amber → red.
    property <color> fill-color:
        ViewportState.perf-memory-fill >= 0.9 ? Theme.error
        : ViewportState.perf-memory-fill >= 0.7 ? Theme.warning
        : Theme.good;

    HorizontalLayout {
        alignment: space-between;
        spacing: Tokens.space-sm;

        Rectangle {
            width: badge-label.preferred-width + 2 * Tokens.space-xs;
            height: 14px;
            border-radius: Tokens.radius-sm;
            background: root.badge-color.with-alpha(0.16);
            border-width: Tokens.hairline;
            border-color: root.badge-color.with-alpha(0.42);

            badge-label := Text {
                text: ViewportState.perf-memory-profile-label;
                color: root.badge-color;
                font-size: Tokens.font-xs;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        Text {
            y: (parent.height - self.height) / 2;
            text: ViewportState.perf-memory-total-text;
            color: Theme.text-dim;
            font-size: Tokens.font-xs;
        }
    }

    if ViewportState.perf-memory-fill >= 0: Rectangle {
        height: 4px;
        border-radius: 2px;
        background: Theme.bg-inset;

        Rectangle {
            x: 0;
            width: parent.width * max(0.02, ViewportState.perf-memory-fill);
            height: 100%;
            border-radius: 2px;
            background: root.fill-color;
        }
    }

    StatRow {
        stat-label: "live";
        stat-value: ViewportState.perf-memory-live-text;
    }
}

export component Hud inherits Rectangle {
    background: transparent;
    opacity: 0.55;
    width: layout.preferred-width;
    height: layout.preferred-height;

    property <color> indicator-color:
        ViewportState.fps-value >= 50 ? Theme.good
        : ViewportState.fps-value >= 25 ? Theme.warning
        : Theme.error;

    property <color> memory-profile-color:
        ViewportState.perf-memory-profile-label == "PERF" ? Theme.good
        : ViewportState.perf-memory-profile-label == "BAL" ? Theme.cyan
        : Theme.warning;

    layout := VerticalLayout {
        spacing: Tokens.space-xs;

        // Device + engine header — unchanged.
        Text {
            text: ViewportState.device-name;
            color: Theme.text-muted;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }
        Text {
            text: ViewportState.engine-name;
            color: Theme.text-faint;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
        }

        // Live FPS line with status dot.
        HorizontalLayout {
            alignment: end;
            spacing: 4px;
            Rectangle {
                width: 4px;
                height: 4px;
                border-radius: 2px;
                background: root.indicator-color;
                y: (parent.height - self.height) / 2;
            }
            Text {
                text: ViewportState.fps-text;
                color: Theme.text-muted;
                font-size: Tokens.font-xs;
            }
        }

        // `PATINAE_PERF=1` → tail-latency rows, memory panel, per-pass GPU times.
        if ViewportState.perf-visible: HudRule {}
        if ViewportState.perf-visible: StatRow {
            stat-label: "avg";
            stat-value: ViewportState.perf-avg-text;
        }
        if ViewportState.perf-visible: StatRow {
            stat-label: "1% low";
            stat-value: ViewportState.perf-low-1pct-text;
        }
        if ViewportState.perf-visible: StatRow {
            stat-label: "0.1% low";
            stat-value: ViewportState.perf-low-0_1pct-text;
        }
        if ViewportState.perf-visible && ViewportState.perf-memory-profile-label != "": HudRule {}
        if ViewportState.perf-visible && ViewportState.perf-memory-profile-label != "": MemoryPanel {
            badge-color: root.memory-profile-color;
        }
        if ViewportState.perf-visible && ViewportState.perf-gpu-text != "": HudRule {}
        if ViewportState.perf-visible && ViewportState.perf-gpu-text != "": Text {
            text: ViewportState.perf-gpu-text;
            color: Theme.text-ghost;
            font-size: Tokens.font-xs;
            horizontal-alignment: right;
            wrap: word-wrap;
        }
    }
}
