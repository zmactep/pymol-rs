// Theme — color palette with dark/light mode switching.
// Single source of truth for all UI chrome colors.

import "fonts/JetBrainsMono-Regular.ttf";
import "fonts/JetBrainsMono-Bold.ttf";
import "fonts/Inter-Regular.ttf";
import "fonts/Inter-Medium.ttf";

export struct NamedColor {
    name: string,
    swatch: color,
}

export global Theme {
    in-out property <bool> dark-mode: true;
    callback toggle-theme();

    // ── Surfaces (elevation) ───────────────────────────────────────
    out property <color> bg:        dark-mode ? #0B0B10 : #F5F1E6;
    out property <color> bg-panel:  dark-mode ? #0E0E14 : #EEE9DA;
    out property <color> bg-raised: dark-mode ? #12121A : #E7E1CF;
    out property <color> bg-inset:  dark-mode ? #15151D : #E1DAC5;
    out property <color> bg-card:   dark-mode ? #191921 : #DAD2BB;

    // ── Separators ─────────────────────────────────────────────────
    out property <color> line:        dark-mode ? #1E1E28 : #D0C8B0;
    out property <color> line-strong: dark-mode ? #2E2E3A : #C0B898;

    // ── Text hierarchy ─────────────────────────────────────────────
    out property <color> text:       dark-mode ? #E5E5EA : #1F1D18;
    out property <color> text-dim:   dark-mode ? #B8B8C0 : #3A362E;
    out property <color> text-muted: dark-mode ? #8E8E98 : #5A5548;
    out property <color> text-faint: dark-mode ? #5A5A63 : #7A7568;
    out property <color> text-ghost: dark-mode ? #3A3A43 : #9A9488;

    // ── Brand accents ──────────────────────────────────────────────
    out property <color> cyan:        dark-mode ? #22D3EE : #0E7490;
    out property <color> cyan-dim:    dark-mode ? #0891B2 : #155E75;
    out property <color> magenta:     dark-mode ? #F472B6 : #BE185D;
    out property <color> magenta-dim: dark-mode ? #BE185D : #9D174D;
    out property <color> violet:      dark-mode ? #A78BFA : #6D28D9;
    out property <color> amber:       dark-mode ? #FDE68A : #B45309;

    // ── Semantic ───────────────────────────────────────────────────
    out property <color> error:   dark-mode ? #EF4444 : #DC2626;
    out property <color> warning: dark-mode ? #F59E0B : #D97706;
    out property <color> good:    dark-mode ? #22C55E : #11952E;

    // ── Chain palette (pushed from Rust via ThemedPalette) ──────
    in property <color> chain-a;
    in property <color> chain-b;
    in property <color> chain-c;
    in property <color> chain-d;
    in property <color> chain-e;
    in property <color> chain-f;

    // ── Solid color swatches for color popover (pushed from Rust) ─
    in property <[NamedColor]> solid-row1;
    in property <[NamedColor]> solid-row2;
    in property <[NamedColor]> solid-row3;

    // ── Secondary structure colors (pushed from Rust) ────────
    in property <color> ss-helix;
    in property <color> ss-loop;
    in property <color> ss-sheet;

    // ── Viewport ───────────────────────────────────────────────────
    out property <color> viewport-bg: dark-mode ? #0B0B10 : #F0EEE7;
}
