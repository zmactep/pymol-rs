// Design tokens — spacing, radii, motion, zone sizing.
// Color tokens are in theme.slint (theme-aware).

export global Tokens {
    // ── Spacing scale ──────────────────────────────────────────────
    out property <length> space-xs:  4px;
    out property <length> space-sm:  8px;
    out property <length> space-md: 14px;
    out property <length> space-lg: 24px;
    out property <length> space-xl: 48px;

    // ── Element sizing ─────────────────────────────────────────────
    out property <length> row-h:      30px;
    out property <length> popover-w: 260px;
    out property <length> tab-bar-h:  36px;
    out property <length> icon-size:  32px;
    out property <length> hairline:  0.5px;

    // ── Typography ─────────────────────────────────────────────────
    out property <length> font-xs:   9px;   // HUD overlay
    out property <length> font-sm:  10px;   // hints, placeholders
    out property <length> font-md:  11px;   // labels, tab headers
    out property <length> font-lg:  13px;   // body (object name)
    out property <length> font-xl:  16px;   // chevron, action-pill icon

    // ── Corner radii ───────────────────────────────────────────────
    out property <length> radius-sm:     4px;
    out property <length> radius-md:     7px;
    out property <length> radius-lg:    11px;
    out property <length> radius-round: 16px;

    // ── Motion ─────────────────────────────────────────────────────
    out property <duration> motion-micro:      80ms;
    out property <duration> motion-base:      160ms;
    out property <duration> motion-atmosphere: 2000ms;

    // ── Zone defaults ──────────────────────────────────────────────
    out property <length> sidebar-w:          48px;
    out property <length> right-dock-default-w: 280px;
    out property <length> right-dock-min-w:   240px;
    out property <length> right-dock-max-w:   420px;
    out property <length> bottom-dock-default-h: 220px;
    out property <length> bottom-dock-min-h:  160px;
    out property <length> bottom-dock-max-h:  400px;

    // ── Row controls (R / L / C cluster, etc.) ────────────────────
    out property <length> row-btn-w:         22px;
    out property <length> row-btn-h:         20px;
    out property <length> row-btn-group-pad:  8px;
    out property <length> row-btn-spacing:    2px;

    // ── Color dot (object / chain indicator) ──────────────────────
    out property <length> dot-size:   8px;
    out property <length> dot-radius: 4px;

    // ── Object list / chevron ─────────────────────────────────────
    out property <length> chevron-w:        16px;
    out property <length> chevron-touch-w:  44px;
    out property <length> chain-row-indent: 44px;
    out property <length> chain-row-h:      26px;
    out property <length> row-gap:           1px;
    out property <length> chain-indicator-w: 22px;

    // ── Selection-list markers ────────────────────────────────────
    out property <length> marker-size:   10px;
    out property <length> marker-inner:   6px;
    out property <length> marker-inner-offset: 2px;

    // ── Action pill — outer shell ─────────────────────────────────
    out property <length> action-pill-h:          48px;
    out property <length> action-pill-radius:     12px;
    out property <length> action-pill-pad-h:      10px;
    out property <length> action-pill-pad-v:      12px;
    out property <length> action-pill-spacing:     4px;
    out property <length> action-pill-bottom-gap: 12px;

    // ── Action pill — inner pieces ────────────────────────────────
    out property <length> action-btn-h:     24px;
    out property <length> action-btn-min-w: 32px;
    out property <length> action-btn-radius: 5px;
    out property <length> badge-size:       18px;
    out property <length> badge-radius:      9px;
    out property <length> action-pill-glow:  2px;
    out property <length> border-stroke:     1px;

    // ── Action pill — icon internals ──────────────────────────────
    out property <length> pill-icon-size:   16px;
    out property <length> pill-icon-stroke: 1.5px;

    // ── REPL pill ────────────────────────────────────────────────
    out property <length> repl-pill-w:       380px;
    out property <length> repl-pill-h:        32px;
    out property <length> repl-pill-radius:   16px;
    out property <length> repl-pill-bottom:   24px;
    out property <length> repl-prompt-size:   13px;
    out property <length> repl-drawer-gap:     4px;
    out property <length> repl-output-pad:     8px;
    out property <length> repl-output-font:   12px;
    out property <length> repl-cmd-echo-pad:   6px;
}
