import { MainLayout } from "layout.slint";
import { LayoutState } from "states/layout-state.slint";
import { ObjectsState } from "states/objects-state.slint";
import { ViewportState } from "states/viewport-state.slint";
import { ReplState, OutputItem, CompletionItem } from "states/repl-state.slint";
import { StartState } from "states/start-state.slint";
import { NotificationState } from "states/notification-state.slint";
import { SequenceState, SeqChainRow } from "states/sequence-state.slint";
import {
    MovieState,
    MovieTick,
    MovieMarker,
    MovieBlock,
    MovieLane,
} from "states/movie-state.slint";
import {
    PluginState,
    PluginToolbarItem,
    PluginPanelTab,
    PluginControl,
    PluginOption,
    PluginButtonItem,
} from "states/plugin-state.slint";
import { MenuState, RecentFileItem } from "states/menu-state.slint";
import { FetchDialog } from "components/fetch-dialog.slint";
import { Theme } from "theme.slint";
import { Tokens } from "tokens.slint";
import { Palette, Button } from "std-widgets.slint";

export { ViewportState, LayoutState, ObjectsState, ReplState, OutputItem, CompletionItem, StartState, NotificationState, SequenceState, SeqChainRow, MovieState, MovieTick, MovieMarker, MovieBlock, MovieLane, PluginState, PluginToolbarItem, PluginPanelTab, PluginControl, PluginOption, PluginButtonItem, MenuState, RecentFileItem, Theme, Tokens, Palette }

export component StartupErrorWindow inherits Window {
    in property <string> dialog-title: "Patinae Renderer Unavailable";
    in property <string> message-text: "";
    callback acknowledged();

    title: root.dialog-title;
    preferred-width: 560px;
    preferred-height: 300px;
    background: Theme.bg;

    VerticalLayout {
        padding: Tokens.space-lg;
        spacing: Tokens.space-md;

        HorizontalLayout {
            height: 44px;
            spacing: Tokens.space-md;

            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 18px;
                background: Theme.error.with-alpha(0.16);
                border-width: 1px;
                border-color: Theme.error.with-alpha(0.55);

                Text {
                    text: "!";
                    color: Theme.error;
                    font-size: 22px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: root.dialog-title;
                color: Theme.text;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.line;
        }

        Text {
            text: root.message-text;
            color: Theme.text-dim;
            font-size: 13px;
            wrap: word-wrap;
            vertical-stretch: 1;
        }

        HorizontalLayout {
            height: 36px;

            Rectangle {
                horizontal-stretch: 1;
            }

            Button {
                text: "OK";
                clicked => {
                    root.acknowledged();
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    forward-focus: app-focus;
    title: "Patinae";
    preferred-width: 1200px;
    preferred-height: 800px;
    background: Theme.bg;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Run Script...";
                shortcut: @keys(Control + R);
                activated => {
                    MenuState.action("run-script");
                }
            }

            MenuSeparator { }

            MenuItem {
                title: "Open...";
                shortcut: @keys(Control + O);
                activated => {
                    MenuState.action("open");
                }
            }

            Menu {
                title: "Open Recent";
                if !MenuState.has-recent-files: MenuItem {
                    title: "No Recent Files";
                    enabled: false;
                }
                for item in MenuState.recent-files: MenuItem {
                    title: item.title;
                    activated => {
                        MenuState.open-recent(item.path);
                    }
                }
            }

            MenuItem {
                title: "Fetch PDB...";
                shortcut: @keys(Control + F);
                activated => {
                    MenuState.action("fetch");
                }
            }

            MenuSeparator { }

            MenuItem {
                title: "Save...";
                shortcut: @keys(Control + S);
                activated => {
                    MenuState.action("save");
                }
            }

            MenuItem {
                title: "Export PNG...";
                shortcut: @keys(Control + Shift + E);
                activated => {
                    MenuState.action("export-png");
                }
            }

            MenuItem {
                title: "Export Movie...";
                activated => {
                    MenuState.action("export-movie");
                }
            }

            MenuSeparator { }

            MenuItem {
                title: "Quit";
                shortcut: @keys(Control + Q);
                activated => {
                    MenuState.action("quit");
                }
            }
        }

        Menu {
            title: "Edit";
            MenuItem {
                title: "Select All Atoms";
                shortcut: @keys(Control + Shift + A);
                activated => {
                    MenuState.action("select-all");
                }
            }

            MenuItem {
                title: "Deselect All";
                activated => {
                    MenuState.action("deselect-all");
                }
            }
        }

        Menu {
            title: "View";
            MenuItem {
                title: "Reset";
                activated => {
                    MenuState.action("reset-view");
                }
            }

            MenuItem {
                title: "Zoom All";
                shortcut: @keys(Control + "0");
                activated => {
                    MenuState.action("zoom-all");
                }
            }

            MenuItem {
                title: "Orient";
                activated => {
                    MenuState.action("orient");
                }
            }

            MenuItem {
                title: "Center";
                activated => {
                    MenuState.action("center");
                }
            }

            MenuSeparator { }

            Menu {
                title: "Background";
                MenuItem {
                    title: "Opaque";
                    checkable: true;
                    checked: false;
                    activated => {
                        MenuState.action("toggle-opaque-background");
                    }
                }

                MenuSeparator { }

                MenuItem {
                    title: "White";
                    activated => {
                        MenuState.action("bg-white");
                    }
                }

                MenuItem {
                    title: "Black";
                    activated => {
                        MenuState.action("bg-black");
                    }
                }
            }

            MenuSeparator { }

            MenuItem {
                title: "Focus REPL";
                shortcut: @keys(Control + L);
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("focus-repl");
                }
            }

            MenuItem {
                title: "Objects Panel";
                checkable: true;
                checked: !LayoutState.empty-mode && LayoutState.objects-visible;
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("panel:objects");
                }
            }

            MenuItem {
                title: "Selections Panel";
                checkable: true;
                checked: !LayoutState.empty-mode && LayoutState.selections-visible;
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("panel:selections");
                }
            }

            MenuItem {
                title: "Sequence Panel";
                checkable: true;
                checked: !LayoutState.empty-mode && LayoutState.sequence-visible;
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("panel:sequence");
                }
            }

            MenuItem {
                title: "Movie Panel";
                checkable: true;
                checked: !LayoutState.empty-mode && LayoutState.movie-visible;
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("panel:movie");
                }
            }

            MenuItem {
                title: "REPL";
                checkable: true;
                checked: !LayoutState.empty-mode && LayoutState.repl-visible;
                enabled: !LayoutState.empty-mode;
                activated => {
                    MenuState.action("panel:repl");
                }
            }

            MenuSeparator { }

            MenuItem {
                title: "Fullscreen";
                activated => {
                    MenuState.action("fullscreen");
                }
            }
        }

        Menu {
            title: "Help";
            MenuItem {
                title: "Command Reference";
                activated => {
                    MenuState.action("help");
                }
            }
        }
    }

    app-focus := FocusScope {
        focus-on-click: false;
    }

    main-layout := MainLayout {
        width: parent.width;
        height: parent.height;
    }

    FetchDialog {
        width: parent.width;
        height: parent.height;
    }

    public function focus-repl() {
        main-layout.focus-repl();
    }

    public function dismiss-repl() {
        main-layout.dismiss-repl();
    }

    public function repl-cursor-to-end() {
        main-layout.repl-cursor-to-end();
    }

    public function sync-widget-theme() {
        Palette.color-scheme = Theme.dark-mode ? ColorScheme.dark : ColorScheme.light;
    }
}
